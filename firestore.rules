rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =================================================================
    // 1. FUNÇÕES DE VALIDAÇÃO GERAIS
    // =================================================================
    function logado() { 
      return request.auth != null; 
    }
    
    function temPermissao(permissao) {
      // 1. Verifica se o documento do utilizador existe
      let userRef = /databases/$(database)/documents/usuarios/$(request.auth.uid);
      
      // 2. Se o user existir, verifica se o perfil também existe e usa o hasAny
      return exists(userRef) && 
             exists(/databases/$(database)/documents/perfis/$(get(userRef).data.perfil)) &&
             get(/databases/$(database)/documents/perfis/$(get(userRef).data.perfil)).data.permissoes.hasAny([permissao]);
    }

    // =================================================================
    // 2. REGRAS DO PAINEL DE ADMINISTRAÇÃO (Segurança Máxima)
    // =================================================================
    
    match /usuarios/{userId} {
      allow read: if logado() && (request.auth.uid == userId || temPermissao('acesso_admin'));
      allow write: if logado() && temPermissao('acesso_admin');
    }

    match /perfis/{perfilId} {
      allow read: if logado();
      allow write: if logado() && temPermissao('acesso_admin');
    }

    // =================================================================
    // 3. REGRAS OPERACIONAIS (Sem sobreposições/wildcards)
    // =================================================================
    
    match /empenhos/{docId} {
      allow read: if logado();
      allow create: if logado() && temPermissao('inserir_dados');
      allow update: if logado() && temPermissao('editar_dados');
      allow delete: if logado() && temPermissao('excluir_dados');
    }

    match /contratos/{docId} {
      allow read: if logado();
      allow create: if logado() && temPermissao('inserir_dados');
      allow update: if logado() && temPermissao('editar_dados');
      allow delete: if logado() && temPermissao('excluir_dados');
    }

    match /darf/{docId} {
      allow read: if logado();
      allow create: if logado() && temPermissao('inserir_dados');
      allow update: if logado() && temPermissao('editar_dados');
      allow delete: if logado() && temPermissao('excluir_dados');
    }

    match /titulos/{docId} {
      allow read: if logado();
      allow create: if logado() && temPermissao('inserir_dados');
      allow update: if logado() && temPermissao('editar_dados');
      allow delete: if logado() && temPermissao('excluir_dados');
    }
  }
}