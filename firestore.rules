rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =================================================================
    // 1. FUNÇÕES DE VALIDAÇÃO GERAIS
    // =================================================================
    function logado() { 
      return request.auth != null; 
    }
    
    function temPermissao(permissao) {
      let userRef = /databases/$(database)/documents/usuarios/$(request.auth.uid);
      if (!exists(userRef)) return false;
      let userDoc = get(userRef).data;
      if (userDoc.bloqueado == true) return false;
      if (userDoc.keys().hasAny(['status']) && userDoc.status == 'pendente') return false;
      let perfis = userDoc.keys().hasAny(['perfis']) ? userDoc.perfis : (userDoc.keys().hasAny(['perfil']) ? [userDoc.perfil] : []);
      let perfilAtivo = userDoc.keys().hasAny(['perfil_ativo']) ? userDoc.perfil_ativo : userDoc.perfil;
      if (perfilAtivo == null) return false;
      let perfilValido = perfis.hasAny([perfilAtivo]);
      if (!perfilValido) return false;
      let permRef = get(/databases/$(database)/documents/perfis/$(perfilAtivo)).data.permissoes;
      if (permRef.hasAny([permissao])) return true;
      // Migração: perfis antigos (inserir_dados, editar_dados, excluir_dados) concedem acesso aos módulos
      let ehInserir = permissao in ['empenhos_inserir','contratos_inserir','darf_inserir','titulos_inserir'];
      let ehEditar = permissao in ['empenhos_editar','contratos_editar','darf_editar','titulos_editar'];
      let ehExcluir = permissao in ['empenhos_excluir','contratos_excluir','darf_excluir','titulos_excluir'];
      return (ehInserir && permRef.hasAny(['inserir_dados'])) || (ehEditar && permRef.hasAny(['editar_dados'])) || (ehExcluir && permRef.hasAny(['excluir_dados']));
    }

    // =================================================================
    // 2. REGRAS DO PAINEL DE ADMINISTRAÇÃO (Segurança Máxima)
    // =================================================================
    
    match /usuarios/{userId} {
      allow read: if logado() && (request.auth.uid == userId || temPermissao('acesso_admin'));
      allow create: if logado() && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['perfis', 'perfil_ativo', 'bloqueado', 'perfil'])
        && (!request.resource.data.keys().hasAny(['status']) || request.resource.data.status == 'pendente');
      allow update, delete: if logado() && temPermissao('acesso_admin');
    }

    match /auditoria/{docId} {
      allow read: if logado() && temPermissao('acesso_admin');
      allow create: if logado() && temPermissao('acesso_admin');
      allow update, delete: if false;
    }

    match /perfis/{perfilId} {
      allow read: if logado();
      allow write: if logado() && temPermissao('acesso_admin');
    }

    // =================================================================
    // 3. REGRAS OPERACIONAIS (Permissões granulares: modulo_acao)
    // =================================================================
    
    match /empenhos/{docId} {
      allow read: if logado() && temPermissao('empenhos_ler');
      allow create: if logado() && temPermissao('empenhos_inserir');
      allow update: if logado() && temPermissao('empenhos_editar');
      allow delete: if logado() && temPermissao('empenhos_excluir');
    }

    match /contratos/{docId} {
      allow read: if logado() && temPermissao('contratos_ler');
      allow create: if logado() && temPermissao('contratos_inserir');
      allow update: if logado() && temPermissao('contratos_editar');
      allow delete: if logado() && temPermissao('contratos_excluir');
    }

    match /darf/{docId} {
      allow read: if logado() && temPermissao('darf_ler');
      allow create: if logado() && temPermissao('darf_inserir');
      allow update: if logado() && temPermissao('darf_editar');
      allow delete: if logado() && temPermissao('darf_excluir');
    }

    match /titulos/{docId} {
      allow read: if logado() && temPermissao('titulos_ler');
      allow create: if logado() && temPermissao('titulos_inserir');
      allow update: if logado() && temPermissao('titulos_editar');
      allow delete: if logado() && temPermissao('titulos_excluir');
    }

    match /oi/{docId} {
      allow read: if logado();
      allow write: if logado() && temPermissao('acesso_admin');
    }
  }
}
