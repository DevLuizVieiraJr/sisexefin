rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =================================================================
    // 1. FUNÇÕES DE VALIDAÇÃO GERAIS
    // =================================================================
    function logado() { 
      return request.auth != null; 
    }
    
    function temPermissao(permissao) {
      let uid = request.auth.uid;
      let userPath = /databases/$(database)/documents/usuarios/$(uid);
      return exists(userPath)
        && get(userPath).data.get('bloqueado', false) != true
        && (!('status' in get(userPath).data) || get(userPath).data.status != 'pendente')
        && _temPermissaoPerfil(permissao, userPath);
    }
    
    function _temPermissaoPerfil(permissao, userPath) {
      let userDoc = get(userPath).data;
      let perfis = ('perfis' in userDoc) ? userDoc.perfis : (('perfil' in userDoc) ? [userDoc.perfil] : []);
      let perfilAtivo = ('perfil_ativo' in userDoc) ? userDoc.perfil_ativo : userDoc.get('perfil', null);
      return perfilAtivo != null
        && perfis.hasAny([perfilAtivo])
        && exists(/databases/$(database)/documents/perfis/$(perfilAtivo))
        && _temPermissaoPermRef(permissao, get(/databases/$(database)/documents/perfis/$(perfilAtivo)).data.get('permissoes', []));
    }
    
    function _temPermissaoPermRef(permissao, permRef) {
      return permRef != null
        && (permRef.hasAny([permissao])
          || (permissao in ['empenhos_inserir','contratos_inserir','fornecedores_inserir','dedenc_inserir','titulos_inserir','lf_inserir','centrocustos_inserir','ug_inserir','op_inserir'] && permRef.hasAny(['inserir_dados']))
          || (permissao in ['empenhos_editar','contratos_editar','fornecedores_editar','dedenc_editar','titulos_editar','lf_editar','centrocustos_editar','ug_editar','op_editar'] && permRef.hasAny(['editar_dados']))
          || (permissao in ['empenhos_excluir','contratos_excluir','fornecedores_excluir','dedenc_excluir','titulos_excluir','lf_excluir','centrocustos_excluir','ug_excluir'] && permRef.hasAny(['excluir_dados'])));
    }

    // Aliases legados (matriz RBAC — ver RN Admin RN-ADM-038)
    function temPermissaoOuAlias(permissao) {
      return temPermissao(permissao)
        || (permissao == 'titulos_status' && temPermissao('titulos_inativar'))
        || (permissao == 'empenhos_cancelar' && temPermissao('empenhos_excluir'))
        || (permissao == 'empenhos_status' && temPermissao('empenhos_excluir'))
        || (permissao == 'lf_cancelar' && temPermissao('lf_excluir'))
        || (permissao == 'lf_status' && temPermissao('lf_excluir'))
        || (permissao == 'fornecedores_cancelar' && temPermissao('fornecedores_excluir'))
        || (permissao == 'fornecedores_status' && temPermissao('fornecedores_excluir'))
        || (permissao == 'centrocustos_cancelar' && temPermissao('centrocustos_excluir'))
        || (permissao == 'centrocustos_status' && temPermissao('centrocustos_excluir'))
        || (permissao == 'ug_cancelar' && temPermissao('ug_excluir'))
        || (permissao == 'ug_status' && temPermissao('ug_excluir'))
        || (permissao == 'contratos_cancelar' && temPermissao('contratos_excluir'))
        || (permissao == 'contratos_status' && temPermissao('contratos_excluir'))
        || (permissao == 'dedenc_cancelar' && temPermissao('dedenc_excluir'))
        || (permissao == 'op_inserir' && temPermissao('titulos_inserir'))
        || (permissao == 'op_editar' && temPermissao('titulos_editar'))
        || (permissao == 'op_cancelar' && (temPermissao('titulos_inserir') || temPermissao('titulos_editar')))
        || (permissao == 'op_status' && (temPermissao('titulos_inserir') || temPermissao('titulos_editar')))
        || (permissao == 'usuarios_status' && (temPermissao('usuarios_editar') || temPermissao('acesso_admin')))
        || (permissao == 'oi_status' && temPermissao('oi_editar'))
        || (permissao == 'oi_cancelar' && temPermissao('oi_editar'));
    }

    function podeExcluirPermanenteMod(modPrefix, permExcluir, permCancelar, permStatus) {
      return temPermissao('acesso_admin')
        || (temPermissao(permExcluir) && (temPermissao(permCancelar) || temPermissao(permStatus)));
    }

    function podeGerirUsuarios() {
      return temPermissao('acesso_admin')
        || temPermissao('usuarios_ler')
        || temPermissao('usuarios_inserir')
        || temPermissao('usuarios_editar')
        || temPermissao('usuarios_excluir')
        || temPermissao('admin_pendentes_ler')
        || temPermissao('admin_cadastrar_usuario');
    }

    function podeLerProprioPerfil(perfilId) {
      let userPath = /databases/$(database)/documents/usuarios/$(request.auth.uid);
      let existe = exists(userPath);
      let userDoc = existe ? get(userPath).data : {};
      let perfis = ('perfis' in userDoc) ? userDoc.perfis : (('perfil' in userDoc) ? [userDoc.perfil] : []);
      return existe
        && userDoc.get('bloqueado', false) != true
        && (!('status' in userDoc) || userDoc.status != 'pendente')
        && perfis.hasAny([perfilId]);
    }

    function ugCamposTextoObrigatorios(d) {
      return d.get('codigo', '') is string && d.get('codigo', '').size() > 0
        && d.get('indicativoNaval', '') is string && d.get('indicativoNaval', '').size() > 0
        && d.get('nome', '') is string && d.get('nome', '').size() > 0;
    }

    // Eventos de fluxo — Títulos de Crédito (catálogo rbac-eventos.js)
    function tituloStatusMudou() {
      return 'status' in request.resource.data
        && 'status' in resource.data
        && request.resource.data.status != resource.data.status;
    }

    function temPermissaoEventoTitulo(eventoId) {
      return temPermissao(eventoId)
        || (eventoId in [
          'titulos_encaminhar_processamento',
          'titulos_encaminhar_liquidacao',
          'titulos_devolver',
          'titulos_retornar_processamento',
          'titulos_retornar_liquidacao'
        ] && temPermissao('tramitarTC'));
    }

    function tituloStatusPosNP(status) {
      return status in ['Liquidado', 'Aguardando Financeiro', 'Para Pagamento', 'Para Pagamento parcial', 'Pago Parcialmente', 'Pago'];
    }

    function podeTransicaoTitulo() {
      let de = resource.data.get('status', 'Rascunho');
      let para = request.resource.data.get('status', 'Rascunho');
      return (de == 'Rascunho' && para == 'Em Processamento' && temPermissaoEventoTitulo('titulos_encaminhar_processamento'))
        || (de == 'Em Processamento' && para == 'Em Liquidação' && temPermissaoEventoTitulo('titulos_encaminhar_liquidacao'))
        || (de in ['Rascunho', 'Em Processamento', 'Em Liquidação'] && para == 'Devolvido' && temPermissaoEventoTitulo('titulos_devolver'))
        || (de == 'Em Liquidação' && para == 'Em Processamento' && temPermissaoEventoTitulo('titulos_retornar_processamento'))
        || (de == 'Liquidado' && para == 'Em Liquidação' && temPermissaoEventoTitulo('titulos_retornar_liquidacao'))
        || (de == 'Devolvido' && para == 'Rascunho' && temPermissao('titulos_nova_entrada'))
        || (de == 'Em Liquidação' && para == 'Liquidado' && temPermissao('liquidacao_fechar_np'))
        || (tituloStatusPosNP(de) && tituloStatusPosNP(para) && temPermissao('liquidacao_editar'))
        || (tituloStatusPosNP(de) && para == 'Em Liquidação' && temPermissao('liquidacao_cancelar'));
    }

    function podeEditarTituloSemMudancaStatus() {
      return temPermissao('titulos_editar')
        || temPermissaoOuAlias('titulos_status')
        || temPermissao('titulos_cancelar')
        || temPermissao('liquidacao_editar')
        || temPermissao('liquidacao_fechar_np')
        || temPermissao('liquidacao_cancelar')
        || temPermissao('liquidacao_informar_op');
    }

    // =================================================================
    // 2. REGRAS DO PAINEL DE ADMINISTRAÇÃO (Segurança Máxima)
    // =================================================================
    
    match /usuarios/{userId} {
      allow read: if logado() && (
        request.auth.uid == userId
        || podeGerirUsuarios()
      );
      // Auto-cadastro: só o próprio uid, sem perfis (fica pendente para aprovação do admin).
      // Cadastro pelo painel admin: grava usuarios/{uid do novo usuário} com perfis — auth.uid é o admin, por isso exige acesso_admin.
      allow create: if logado() && (
        (request.auth.uid == userId
          && !request.resource.data.keys().hasAny(['perfis', 'perfil_ativo', 'bloqueado', 'perfil'])
          && (!request.resource.data.keys().hasAny(['status']) || request.resource.data.status == 'pendente'))
        || temPermissao('acesso_admin')
        || temPermissao('usuarios_inserir')
        || temPermissao('admin_cadastrar_usuario')
      );
      allow update: if logado() && (
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['perfil_ativo']))
        || temPermissao('acesso_admin')
        || temPermissao('usuarios_editar')
        || temPermissaoOuAlias('usuarios_status')
        || temPermissao('admin_cadastrar_usuario')
      );
      allow delete: if logado() && (temPermissao('acesso_admin') || temPermissao('usuarios_excluir'));
    }

    match /auditoria/{docId} {
      allow read: if logado() && temPermissao('acesso_admin');
      allow create: if logado() && temPermissao('acesso_admin');
      allow update, delete: if false;
    }

    match /perfis/{perfilId} {
      allow read: if logado() && (
        temPermissao('acesso_admin')
        || podeLerProprioPerfil(perfilId)
        || temPermissao('usuarios_ler')
        || temPermissao('admin_pendentes_ler')
        || temPermissao('admin_cadastrar_usuario')
      );
      allow write: if logado() && temPermissao('acesso_admin');
    }

    // =================================================================
    // 3. REGRAS OPERACIONAIS (Permissões granulares: modulo_acao)
    // =================================================================
    
    match /empenhos/{docId} {
      allow read: if logado() && temPermissao('empenhos_ler');
      allow create: if logado() && temPermissao('empenhos_inserir');
      allow update: if logado() && (
        temPermissao('empenhos_editar')
        || temPermissaoOuAlias('empenhos_cancelar')
        || temPermissaoOuAlias('empenhos_status')
      );
      allow delete: if logado() && podeExcluirPermanenteMod('empenhos', 'empenhos_excluir', 'empenhos_cancelar', 'empenhos_status');
    }

    match /contratos/{docId} {
      allow read: if logado() && temPermissao('contratos_ler');
      allow create: if logado() && temPermissao('contratos_inserir');
      allow update: if logado() && (
        temPermissao('contratos_editar')
        || temPermissaoOuAlias('contratos_cancelar')
        || temPermissaoOuAlias('contratos_status')
      );
      allow delete: if logado() && podeExcluirPermanenteMod('contratos', 'contratos_excluir', 'contratos_cancelar', 'contratos_status');
    }

    // Fornecedores: leitura só de ativos para não-admin; delete permanente granular
    match /fornecedores/{docId} {
      allow read: if logado() && temPermissao('fornecedores_ler') && (resource.data.get('ativo', true) == true || temPermissao('acesso_admin') || temPermissaoOuAlias('fornecedores_status'));
      allow create: if logado() && temPermissao('fornecedores_inserir');
      allow update: if logado() && (
        temPermissao('fornecedores_editar')
        || temPermissaoOuAlias('fornecedores_status')
        || temPermissaoOuAlias('fornecedores_cancelar')
        || temPermissao('acesso_admin')
      );
      allow delete: if logado() && podeExcluirPermanenteMod('fornecedores', 'fornecedores_excluir', 'fornecedores_cancelar', 'fornecedores_status');
    }

    match /deducoesEncargos/{docId} {
      allow read: if logado() && (temPermissao('dedenc_ler') || temPermissao('relatorios_ler'));
      allow create: if logado() && temPermissao('dedenc_inserir');
      allow update: if logado() && (
        temPermissao('dedenc_editar')
        || temPermissaoOuAlias('dedenc_status')
        || temPermissaoOuAlias('dedenc_cancelar')
        || temPermissao('acesso_admin')
      );
      allow delete: if logado() && (podeExcluirPermanenteMod('dedenc', 'dedenc_excluir', 'dedenc_cancelar', 'dedenc_status') || temPermissao('acesso_admin'));
    }

    match /titulos/{docId} {
      allow read: if logado() && (temPermissao('titulos_ler') || temPermissao('relatorios_ler'));
      allow create: if logado() && temPermissao('titulos_inserir');
      allow update: if logado() && (
        temPermissao('acesso_admin')
        || (!tituloStatusMudou() && podeEditarTituloSemMudancaStatus())
        || (tituloStatusMudou() && podeTransicaoTitulo())
      );
      allow delete: if logado() && temPermissao('titulos_excluir');
    }

    match /oi/{docId} {
      allow read: if logado() && (temPermissao('oi_ler') || temPermissao('acesso_admin'));
      allow create: if logado() && (temPermissao('oi_inserir') || temPermissao('acesso_admin'));
      allow update: if logado() && (
        temPermissao('oi_editar')
        || temPermissaoOuAlias('oi_status')
        || temPermissaoOuAlias('oi_cancelar')
        || temPermissao('acesso_admin')
      );
      allow delete: if logado() && (podeExcluirPermanenteMod('oi', 'oi_excluir', 'oi_cancelar', 'oi_status') || temPermissao('acesso_admin'));
    }

    match /lfpf/{docId} {
      allow read: if logado() && (temPermissao('lf_ler') || temPermissao('liquidacao_ler') || temPermissao('acesso_admin'));
      allow create: if logado() && temPermissao('lf_inserir');
      allow update: if logado() && (
        temPermissao('lf_editar')
        || temPermissaoOuAlias('lf_cancelar')
        || temPermissaoOuAlias('lf_status')
      );
      allow delete: if logado() && podeExcluirPermanenteMod('lf', 'lf_excluir', 'lf_cancelar', 'lf_status');
    }

    // Nota de Pagamento (NP) - coleção para vincular Títulos e documentos (OP/OB)
    match /np/{docId} {
      allow read: if logado() && (
        temPermissao('op_ler') || temPermissao('titulos_ler')
        || temPermissao('preliquidacao_ler') || temPermissao('liquidacao_ler')
        || temPermissao('acesso_admin'));
      allow create: if logado() && (
        temPermissaoOuAlias('op_inserir')
        || temPermissao('titulos_inserir') || temPermissao('titulos_editar')
        || temPermissao('liquidacao_fechar_np')
        || temPermissao('acesso_admin'));
      allow update: if logado() && (
        temPermissaoOuAlias('op_editar')
        || temPermissaoOuAlias('op_cancelar')
        || temPermissaoOuAlias('op_status')
        || temPermissao('titulos_inserir') || temPermissao('titulos_editar')
        || temPermissao('liquidacao_fechar_np') || temPermissao('liquidacao_cancelar')
        || temPermissao('acesso_admin'));
      allow delete: if logado() && (podeExcluirPermanenteMod('op', 'op_excluir', 'op_cancelar', 'op_status') || temPermissao('acesso_admin'));
    }

    // Contadores atómicos (transação na app), incluindo PL, LP e PROC de TC.
    match /contadores/{docId} {
      allow read: if logado() && (
        temPermissao('preliquidacao_ler') || temPermissao('preliquidacao_inserir')
        || temPermissao('liquidacao_ler') || temPermissao('liquidacao_inserir')
        || temPermissao('acesso_admin'));
      allow create, update: if logado() && (
        temPermissao('acesso_admin')
        || temPermissao('preliquidacao_inserir')
        || temPermissao('liquidacao_inserir')
        || (docId == 'titulos_proc_global' && (temPermissao('titulos_inserir') || temPermissao('titulos_editar')))
      );
      allow delete: if logado() && temPermissao('acesso_admin');
    }

    // Pré-Liquidação (lotes / DAuLiq)
    match /preLiquidacoes/{docId} {
      allow read: if logado() && (
        temPermissao('acesso_admin')
        || (temPermissao('preliquidacao_ler')
          && (resource.data.get('ativo', true) == true || temPermissao('preliquidacao_status')))
      );
      allow create: if logado() && (temPermissao('preliquidacao_inserir') || temPermissao('acesso_admin'));
      allow update: if logado() && (
        temPermissao('preliquidacao_editar')
        || temPermissao('preliquidacao_cancelar')
        || temPermissao('preliquidacao_fechar_np')
        || temPermissao('preliquidacao_status')
        || temPermissao('acesso_admin')
      );
      allow delete: if logado() && (temPermissao('preliquidacao_excluir') || temPermissao('acesso_admin'));
    }

    // Liquidação e Pagamento (lotes / DAuLiq) — módulo sucessor da Pré-Liquidação
    match /liquidacoes/{docId} {
      allow read: if logado() && (
        temPermissao('acesso_admin')
        || temPermissao('relatorios_ler')
        || (temPermissao('liquidacao_ler')
          && (resource.data.get('ativo', true) == true || temPermissao('liquidacao_status')))
      );
      allow create: if logado() && (temPermissao('liquidacao_inserir') || temPermissao('acesso_admin'));
      allow update: if logado() && (
        temPermissao('liquidacao_editar')
        || temPermissao('liquidacao_cancelar')
        || temPermissao('liquidacao_fechar_np')
        || temPermissao('liquidacao_informar_op')
        || temPermissao('liquidacao_restaurar')
        || temPermissao('liquidacao_status')
        || temPermissao('acesso_admin')
      );
      allow delete: if logado() && (temPermissao('liquidacao_excluir') || temPermissao('acesso_admin'));
    }

    match /config/{docId} {
      allow read: if logado();
      allow write: if logado() && temPermissao('acesso_admin');
    }

    // Centro de Custos: leitura só de ativos para não-admin; delete permanente só ADMIN
    match /centroCustos/{docId} {
      allow read: if logado() && temPermissao('centrocustos_ler') && (resource.data.get('ativo', true) == true || temPermissao('acesso_admin') || temPermissaoOuAlias('centrocustos_status'));
      allow create: if logado() && temPermissao('centrocustos_inserir');
      allow update: if logado() && (
        temPermissao('centrocustos_editar')
        || temPermissaoOuAlias('centrocustos_status')
        || temPermissaoOuAlias('centrocustos_cancelar')
        || temPermissao('acesso_admin')
      );
      allow delete: if logado() && podeExcluirPermanenteMod('centrocustos', 'centrocustos_excluir', 'centrocustos_cancelar', 'centrocustos_status');
    }

    // Unidade Gestora (UG): leitura só de ativos para não-admin; delete permanente granular
    match /unidadesGestoras/{docId} {
      allow read: if logado() && temPermissao('ug_ler') && (resource.data.get('ativo', true) == true || temPermissao('acesso_admin') || temPermissaoOuAlias('ug_status'));
      allow create: if logado() && temPermissao('ug_inserir') && ugCamposTextoObrigatorios(request.resource.data);
      allow update: if logado() && (
        temPermissao('ug_editar')
        || temPermissaoOuAlias('ug_status')
        || temPermissaoOuAlias('ug_cancelar')
        || temPermissao('acesso_admin')
      ) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ativo'])
        || ugCamposTextoObrigatorios(request.resource.data)
      );
      allow delete: if logado() && podeExcluirPermanenteMod('ug', 'ug_excluir', 'ug_cancelar', 'ug_status');
    }
  }
}
